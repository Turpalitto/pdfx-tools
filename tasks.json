{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "▶ Dev Server",
      "type": "shell",
      "command": "npm run dev",
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "new", "clear": true },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": { "regexp": "." },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "ready in"
        }
      }
    },
    {
      "label": "🔨 Build",
      "type": "shell",
      "command": "npm run build",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": "$tsc"
    },
    {
      "label": "🔍 Lint",
      "type": "shell",
      "command": "npx eslint src --ext .js,.jsx --fix",
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": "$eslint-stylish"
    },
    {
      "label": "✨ Format (Prettier)",
      "type": "shell",
      "command": "npx prettier --write \"src/**/*.{js,jsx,css,json}\"",
      "group": "test",
      "presentation": { "reveal": "silent", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "📦 Install Dependencies",
      "type": "shell",
      "command": "npm install",
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": []
    },
    {
      "label": "🚀 Build + Preview",
      "dependsOrder": "sequence",
      "dependsOn": ["🔨 Build"],
      "type": "shell",
      "command": "npm run preview",
      "presentation": { "reveal": "always", "panel": "new" },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "🧹 Clean + Rebuild",
      "type": "shell",
      "command": "rm -rf dist node_modules/.vite && npm run build",
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": "$tsc"
    }
  ]
}
